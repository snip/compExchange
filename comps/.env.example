# ──────────────────────────────────────────────────────────────────────────────
# CompExchange — competition configuration
# Copy this file to <comp-name>.env and fill in the values.
# Example: comps/tour-de-france.env
#
# The filename stem (without .env) becomes the URL path:
#   comps/tour-de-france.env  →  http://localhost:8080/tour-de-france/
# ──────────────────────────────────────────────────────────────────────────────

# Discord bot token (required).
# Create a bot at https://discord.com/developers/applications
# Required bot permissions: Read Messages, Read Message History
# Required Gateway Intents: Message Content Intent + Server Members Intent
BOT_TOKEN=your-discord-bot-token-here

# Discord channel ID(s) to monitor (required).
# Right-click a channel in Discord → "Copy Channel ID" (Developer Mode must be on).
# Multiple channels can be comma-separated: 123456789,987654321
CHANNEL_ID=your-channel-id-here

# Number of messages to keep in the in-memory buffer (optional, default: 20).
# New viewers will see up to this many recent messages on first load.
BUFFER_SIZE=20

# Full GlideAndSeek URL to embed in the background iframe (required).
# Build your URL on https://glideandseek.com and paste the full address here.
# Example: https://glideandseek.com/?embed=compexchange&taskUrl=https://example.com/task.tsk
GLIDE_URL=https://glideandseek.com/?embed=compexchange

# Human-readable competition name shown in the menu and at the top of the viewer (optional).
# Falls back to the filename stem if not set.
# Example: Championnat de France Club 2026
COMP_NAME=

# Official competition website (optional). If set, the title bar links to it.
# Example: https://www.soaringspot.com/en_gb/my-comp/
COMP_WEBSITE=
